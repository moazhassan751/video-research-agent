# ============================================
# API Keys for the Video Research Agent
# ============================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control!
#
# Get your keys from:
#   SERPAPI_KEY   -> https://serpapi.com/dashboard (free tier: 100 searches/month)
#   GROQ_API_KEY -> https://console.groq.com/keys (covers both LLaMA + Whisper)

SERPAPI_KEY=your_serpapi_key_here
GROQ_API_KEY=your_groq_api_key_here
